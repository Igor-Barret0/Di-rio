# ══════════════════════════════════════════════════════════
#  BACKEND — Variáveis de Produção
#  Copie este arquivo para .env e preencha os valores
#  NÃO commite o .env no git
# ══════════════════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────────────────
NODE_ENV=production
PORT=8080
API_URL=https://SEU-APP.fly.dev
FRONTEND_URL=https://SEU-APP.vercel.app

# ── DATABASE (Neon) ────────────────────────────────────────
# Copie de: console.neon.tech → seu projeto → Connection string
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/diario?sslmode=require

# ── REDIS (Upstash) ────────────────────────────────────────
# Copie de: console.upstash.com → seu database → .env → REDIS_URL
REDIS_URL=rediss://default:SENHA@seu-host.upstash.io:6379

# ── JWT — GERE COM: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=COLE_AQUI_STRING_ALEATORIA_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=COLE_AQUI_OUTRA_STRING_ALEATORIA_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ── GOOGLE OAUTH ───────────────────────────────────────────
# Callback deve ser: https://SEU-APP.fly.dev/api/auth/google/callback
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_CALLBACK_URL=https://SEU-APP.fly.dev/api/auth/google/callback

# ── IA ─────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini

# ── EMAIL (SendGrid) ───────────────────────────────────────
SENDGRID_API_KEY=SG.sua_chave
SENDGRID_FROM_EMAIL=noreply@seudominio.com
SENDGRID_FROM_NAME=Diário Emocional

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGIN=https://SEU-APP.vercel.app

# ── LOGGING ────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ── RATE LIMITING ──────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100