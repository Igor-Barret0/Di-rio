# ── SERVIDOR ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ── DATABASE ──────────────────────────────────────────────
DATABASE_URL=postgresql://diary_user:diary_pass@localhost:5432/diary_db

# ── REDIS ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=troque_por_string_aleatoria_minimo_32_caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=outro_segredo_aleatorio_para_refresh_token
JWT_REFRESH_EXPIRES_IN=30d

# ── GOOGLE OAUTH ──────────────────────────────────────────
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ── IA - DESENVOLVIMENTO ──────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini

# ── IA - PRODUÇÃO ─────────────────────────────────────────
OPENAI_API_KEY=sua_chave_openai

# ── EMAIL ─────────────────────────────────────────────────
SENDGRID_API_KEY=sua_chave_sendgrid
SENDGRID_FROM_EMAIL=noreply@diarioemocional.com
SENDGRID_FROM_NAME=Diário Emocional

# ── AWS S3 (Backups / Áudio) ─────────────────────────────
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_S3_BUCKET=diary-backups
AWS_REGION=us-east-1

# ── LOGGING ───────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
